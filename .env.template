# ══════════════════════════════════════════════════
# APEX CRYPTO TRADING SYSTEM — .env.template
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ══════════════════════════════════════════════════

# ── MEXC API KEYS ──────────────────────────────────
# Get from: https://www.mexc.com/user/openapi
# Enable: Spot Trading, Futures Trading, Read
# DO NOT enable withdrawals
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# ── TELEGRAM BOT ───────────────────────────────────
# 1. Open Telegram, search @BotFather
# 2. Send /newbot, follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# 4. Start your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Send a message to your bot, copy the chat_id
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── CRYPTOPANIC (News Feed) ─────────────────────────
# Free at: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# ── DATABASE ────────────────────────────────────────
# Change this to a strong password
POSTGRES_PASSWORD=change_this_strong_password_123

# ── DASHBOARD ───────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change_this_dashboard_password

# ── GRAFANA ─────────────────────────────────────────
GRAFANA_PASSWORD=change_this_grafana_password
